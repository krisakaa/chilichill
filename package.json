{
  "name": "chilichill-diary",
  "private": true,
  "version": "0.0.0",
  "description": "ChiliChill 巡演像素日记 — Web + App 粉丝留言产品",
  "scripts": {
    "dev:web": "pnpm --filter web dev",
    "build:web": "pnpm --filter web build",
    "check:web": "pnpm --filter web typecheck && pnpm --filter web build",
    "dev:mobile": "pnpm --filter mobile start",
    "lint": "pnpm -r run lint",
    "typecheck": "pnpm -r run typecheck"
  },
  "devDependencies": {
    "typescript": "^5.6.3",
    "turbo": "^2.3.3"
  },
  "packageManager": "pnpm@11.8.0",
  "engines": {
    "node": ">=20"
  },
"pnpm": {
  "onlyBuiltDependencies": [
    "@parcel/watcher",
    "esbuild",
    "turbo",
    "sharp"
  ]
}